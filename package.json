{
  "name": "tensorchat",
  "version": "1.0.0",
  "description": "Privacy-first on-device AI chatbot for iOS and Android. All LLM inference runs locally via llama.rn.",
  "license": "Apache-2.0",
  "author": "General Intelligence Inc.",
  "homepage": "https://github.com/general-intelligence-inc/tensorchat",
  "repository": {
    "type": "git",
    "url": "https://github.com/general-intelligence-inc/tensorchat.git"
  },
  "bugs": {
    "url": "https://github.com/general-intelligence-inc/tensorchat/issues"
  },
  "keywords": [
    "react-native",
    "expo",
    "llm",
    "on-device",
    "llama",
    "privacy",
    "chatbot",
    "ai",
    "gguf",
    "ios",
    "android"
  ],
  "main": "index.ts",
  "scripts": {
    "postinstall": "node scripts/setup-sherpa-voice.js && node scripts/patch-react-native-textkit-warning.js && node scripts/patch-op-sqlite-libsql.js && node scripts/patch-fmt-consteval.js",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "ios:dev:release": "expo run:ios --device --configuration Release",
    "build:release-like:ios:local": "PATH=/opt/homebrew/bin:$PATH npm_config_cache=.npm-cache npx eas-cli@latest build -p ios --profile production-internal --local",
    "build:release:ios": "npx eas-cli@latest build -p ios --profile production",
    "build:release:android": "npx eas-cli@latest build -p android --profile production",
    "build:local:ios": "EXPO_NO_DOCTOR=1 PATH=/opt/homebrew/bin:$PATH npm_config_cache=.npm-cache npx eas-cli@latest build -p ios --profile production --local --output build-ios.ipa",
    "build:local:android": "EXPO_NO_DOCTOR=1 PATH=/opt/homebrew/bin:$PATH npm_config_cache=.npm-cache npx eas-cli@latest build -p android --profile production --local --output build-android.aab",
    "submit:release:ios": "npx eas-cli@latest submit -p ios --profile production",
    "submit:release:android": "npx eas-cli@latest submit -p android --profile production",
    "ship:ios": "npm run build:local:ios && npx eas-cli@latest submit -p ios --profile production --path build-ios.ipa",
    "ship:android": "npm run build:local:android && npx eas-cli@latest submit -p android --profile production --path build-android.aab",
    "test:kokoro-phonemizer": "node scripts/test-kokoro-phonemizer.js",
    "test:think-parser": "node scripts/test-think-parser.js",
    "test:e2e": "maestro test .maestro/tests/",
    "test:e2e:smoke": "maestro test .maestro/tests/smoke/",
    "test:e2e:lfm-350m": "maestro test .maestro/tests/lfm-350m.yaml",
    "test:e2e:lfm-12b": "maestro test .maestro/tests/lfm-12b.yaml",
    "test:e2e:qwen-08b": "maestro test .maestro/tests/qwen-08b.yaml",
    "test:e2e:qwen-2b": "maestro test .maestro/tests/qwen-2b.yaml",
    "test:e2e:qwen-4b": "maestro test .maestro/tests/qwen-4b.yaml",
    "test:e2e:gemma-e2b": "maestro test .maestro/tests/gemma-e2b.yaml",
    "test:miniapp": "npx tsx scripts/test-miniapp-local.ts",
    "test:miniapp:llama": "bash scripts/start-llama-server.sh",
    "test:miniapp:e2e": "npx tsx scripts/test-miniapp-e2e.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@op-engineering/op-sqlite": "14.1.4",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-rag/op-sqlite": "^0.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "babel-preset-expo": "~55.0.8",
    "expo": "~55.0.11",
    "expo-build-properties": "~55.0.11",
    "expo-camera": "~55.0.15",
    "expo-dev-client": "~55.0.22",
    "expo-device": "~55.0.12",
    "expo-document-picker": "~55.0.11",
    "expo-file-system": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-image-manipulator": "~55.0.13",
    "expo-image-picker": "~55.0.16",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "llama.rn": "github:zhi-x-ye/llama.rn#76f27cd02a6086faf7bb72b299b8ac5551800255",
    "onnxruntime-react-native": "^1.24.3",
    "phonemizer": "^1.2.1",
    "punycode": "^2.3.1",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-audio-api": "^0.11.6",
    "react-native-document-ocr": "file:packages/react-native-document-ocr",
    "react-native-enriched-markdown": "0.4.0-nightly-20260307-76f37d3d1",
    "react-native-fs": "^2.20.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-pdfium": "https://raw.githubusercontent.com/software-mansion-labs/private-mind/main/react-native-pdfium-0.1.3.tgz",
    "react-native-phonemis": "file:packages/react-native-phonemis",
    "react-native-rag": "^0.2.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-sherpa-voice": "file:packages/react-native-sherpa-voice",
    "react-native-svg": "15.15.3",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "react-native-zip-archive": "^7.0.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "op-sqlite": {
    "libsql": true,
    "sqliteVec": true
  }
}
